# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=crawldb

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Crawler settings
CRAWLER_CONCURRENCY=20
CRAWLER_DELAY_MS=200
MAX_DEPTH=3
USER_AGENT=CrawlDB/1.0 (+https://github.com/crawldb)
SAME_DOMAIN_ONLY=true

# API settings
API_HOST=0.0.0.0
API_PORT=8000
